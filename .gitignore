# Raw asset downloads — extracted zips, not needed in version control
assets/_downloads/

# Godot-specific ignores

# Godot 4 import cache — regenerated by the editor on open
.godot/

# Export templates and compiled binaries
*.exe
*.x86_64
*.x86
*.arm64
*.arm32
*.wasm
*.apk
*.aab
*.ipa
*.zip

# macOS metadata
.DS_Store

# Windows thumbnail cache
Thumbs.db

# Visual Studio Code settings (optional — remove if you want to share them)
.vscode/

# User-specific editor settings (layout, breakpoints, etc.)
# These live inside .godot/ which is already ignored above

# Compiled GDScript / C# artifacts
*.mono/
.mono/
